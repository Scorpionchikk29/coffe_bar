generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model categories {
  id       Int        @id @default(autoincrement())
  title    String     @db.VarChar(100)
  products products[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id             Int      @id @default(autoincrement())
  order_id       Int
  product_id     Int
  quantity       Int
  price          Decimal  @db.Decimal(12, 2)
  customizations Json?
  orders         orders   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products       products @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order_id")
  @@index([product_id], map: "idx_order_items_product_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id          Int           @id @default(autoincrement())
  user_id     Int
  status_id   Int
  total_price Decimal       @db.Decimal(12, 2)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  pickup_time DateTime?     @db.Timestamptz(6)
  order_items order_items[]
  statuses    statuses      @relation(fields: [status_id], references: [id], onUpdate: NoAction)
  users       users         @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([status_id], map: "idx_orders_status_id")
  @@index([user_id], map: "idx_orders_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model products {
  id           Int           @id @default(autoincrement())
  category_id  Int
  name         String        @db.VarChar(255)
  description  String?       @db.VarChar(255)
  price        Decimal       @db.Decimal(12, 2)
  image_url    String?       @db.VarChar(2048)
  is_available Boolean       @default(true)
  order_items  order_items[]
  categories   categories    @relation(fields: [category_id], references: [id], onUpdate: NoAction)

  @@index([category_id], map: "idx_products_category_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model roles {
  id    Int     @id @default(autoincrement())
  title String  @db.VarChar(50)
  users users[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model statuses {
  id     Int      @id @default(autoincrement())
  title  String   @db.VarChar(50)
  orders orders[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_profiles {
  id          Int     @id
  first_name  String  @db.VarChar(50)
  middle_name String? @db.VarChar(50)
  last_name   String  @db.VarChar(50)
  email       String  @unique @db.VarChar(254)
  phone       String? @db.VarChar(30)
  users       users   @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id            Int            @id @default(autoincrement())
  password_hash String         @db.Char(60)
  role_id       Int
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  orders        orders[]
  user_profiles user_profiles?
  roles         roles          @relation(fields: [role_id], references: [id], onUpdate: NoAction)

  @@index([role_id], map: "idx_users_role_id")
}
